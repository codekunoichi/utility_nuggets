# ============================================================
# Slack Workspace Audit Tool — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required: Slack bot token (xoxb-...) or user token (xoxp-...)
# Minimum required scopes:
#   channels:read      — list public channels
#   channels:history   — read public channel message history
#   groups:read        — list private channels the app belongs to
#   groups:history     — read private channel history
SLACK_BOT_TOKEN=xoxb-your-token-here

# Optional: lookback window for message counting (default: 30)
SLACK_DAYS_LOOKBACK=30

# Optional: days of silence before a channel is considered stale (default: 30)
SLACK_STALE_DAYS=30

# Optional: minimum messages in the lookback window to classify as "active" (default: 10)
SLACK_ACTIVE_MESSAGE_THRESHOLD=10

# Optional: output directory for generated reports (default: reports)
OUTPUT_DIR=reports

# Optional: comma-separated list of output formats — csv, json, or both (default: csv,json)
OUTPUT_FORMATS=csv,json

# ============================================================
# Deployment Digest (digest_main.py) — additional variables
# ============================================================

# Required: Slack channel ID or name where CI/CD bots post deployment notifications
SLACK_DEPLOYMENT_CHANNEL=C0123DEPLOY

# Required: Slack channel ID or name that receives post-deploy impact alerts
SLACK_IMPACT_CHANNEL=C0456IMPACT

# Optional: how many days back to scan for deployments (default: 7 = weekly)
DIGEST_LOOKBACK_DAYS=7

# Optional: minutes after a deploy to look for impact events (default: 30)
IMPACT_WINDOW_MINUTES=30
