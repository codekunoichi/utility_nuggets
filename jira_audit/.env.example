# ============================================================
# Jira Project Activity Audit Tool — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required: Your Jira Cloud base URL (no trailing slash)
JIRA_BASE_URL=https://your-org.atlassian.net

# Required: Email address associated with your Atlassian account
JIRA_USER_EMAIL=your-email@example.com

# Required: Jira API token (NOT your Atlassian password)
# Generate one at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here

# Optional: Lookback window for activity counting in days (default: 30)
JIRA_DAYS_LOOKBACK=30

# Optional: Days of inactivity that mark a project as stale (default: 30)
JIRA_STALE_DAYS=30

# Optional: Minimum issue count in lookback window to classify as "active" (default: 5)
JIRA_ACTIVE_ISSUE_THRESHOLD=5

# Optional: Unresolved issue count above which a project may be "overloaded" (default: 100)
JIRA_OVERLOADED_UNRESOLVED_THRESHOLD=100

# Optional: Output directory for generated reports (default: reports)
OUTPUT_DIR=reports

# Optional: Comma-separated output formats — csv, json, or both (default: csv,json)
OUTPUT_FORMATS=csv,json
